                        {% render 'icon-arrow-right' %}
                      </button>
                    </div>

                    {%- if form.errors -%}
                      <p class="form__field-error" id="{{ id }}-error">
                        {{ form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email }}
                      </p>
                    {%- endif -%}
