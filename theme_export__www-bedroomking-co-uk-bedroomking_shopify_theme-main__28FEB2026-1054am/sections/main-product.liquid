                        class="btn {% if enable_dynamic_checkout %}btn--secondary{% else %}btn--primary{% endif %} w-full"
                        name="add"
                        {% if current_variant.available == false %}
                          disabled
                        {% endif %}
                      >
                        {%- if current_variant.available -%}
                          {{- add_to_cart_text -}}
                        {%- else -%}
                          {{- 'products.product.sold_out' | t -}}
                        {%- endif -%}
                      </button>
                    </div>
                  </div>

                  {%- if enable_dynamic_checkout -%}
                    {{ form | payment_button }}
                  {%- endif -%}
                {%- endform -%}
              </product-form>

              {%- if block.settings.show_pickup_availability -%}
                {% render 'pickup-availability', current_variant: current_variant %}
              {%- endif -%}
            </div>

            <!-- timeline widget -->
