co.uk\/collections\/mattresses\">mattress<\/a>. This all-in-one solution ensures a seamless and coordinated look for your bedroom with our <a href=\"https:\/\/www.bedroomking.co.uk\/collections\/sleigh-beds\" target=\"_blank\" title=\"https:\/\/www.bedroomking.co.uk\/collections\/sleigh-beds\">Upholstered sleigh bed<\/a>, providing both style and comfort. A sleigh bed frame paired with a high-quality mattress offers both aesthetic appeal and exceptional sleep quality.<\/p>","enlarge_text":false}}},"block_order":["heading_K3f7pf","text_NQddfM"],"custom_css":[".cc-media-with-text {background: #efefef;}",".section__block.section__block--heading {font-size: 30px; color: #806642;}",".section__block.reading-width p {line-height: 1.8; font-size: 16px; color: #555;}"],"settings":{"image":"shopify:\/\/shop_images\/2_3_a2c191f7-1303-4d1a-ac03-2a27191520b2.png","video_external":"","video_description":"","video_autoplay":false,"layout":"right","image_fit":"contain","media_width":50,"media_scale":100,"text_align":"text-start","color_scheme":"none"}},"slideshow_qPbrMH":{"type":"slideshow","blocks":{"slide_afqbmd":{"type":"slide","disabled":true,"settings":{"image_desktop":"shopify:\/\/shop_images\/Desktop_-_1_22.png","url":"","overlay_position":"justify-center items-center","overlay_text_align":"text-center","mob_center_text":false,"subheading":"","heading":"","heading_color":"#ffffff","heading_size":"h0","heading_h1":false,"text":"","enlarge_text":true,"button_1_label":"","button_1_link":"","button_1_style":"btn btn--primary","button_2_label":"","button_2_link":"","button_2_style":"btn btn--primary","transparent_content_color":"#ffffff","countdown_show":false,"countdown_end_date":"","countdown_end_time":"","countdown_end_text":"","enlarge_end_text":false,"countdown_hide_on_end":false,"use_custom_colors":false,"count_color":"#ffffff","bg_color":"#070707","bg_grad":""}}},"block_order":["slide_afqbmd"],"settings":{"height_mode":"auto","fixed_height_desktop":600,"fixed_height_mobile