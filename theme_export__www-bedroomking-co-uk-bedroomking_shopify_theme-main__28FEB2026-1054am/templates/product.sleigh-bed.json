r swift<br\/>delivery, bringing comfort and elegance to your home quickly.<\/p>","button_label":"","button_link":""}}},"block_order":["column_4xDcCj","column_A6gNWq"],"disabled":true,"settings":{"title":"","heading_align":"text-center","button_label":"","button_link":"","layout":"grid","column_size":"medium","column_align":"center","image_ratio":"natural","color_scheme":"1","button_style":"btn btn--secondary"}},"recommendations":{"type":"product-recommendations","settings":{"heading":"YOU MAY ALSO LIKE","heading_align":"text-center","layout":"carousel","card_size_mobile":"large","card_size":"small","products_to_show":8}},"apps_DEDC6d":{"type":"apps","blocks":{"air_product_reviews_app_block_review_list_cBwAyD":{"type":"shopify:\/\/apps\/air-product-reviews\/blocks\/app-block-review-list\/c4e1e9ca-4d46-4e76-bc39-7e42417cb327","settings":{"air_blockreviews_summaryHeading":"Reviews","air_blockreviews_layout":"list","air_blockreviews_singleStarColor":"#16a086","air_blockreviews_primaryColor":"#121212"}}},"block_order":["air_product_reviews_app_block_review_list_cBwAyD"],"settings":{"full_width":false}},"faq_9gUH8K":{"type":"faq","blocks":{"question_MUVNpT":{"type":"question","settings":{"icon":"none","heading":"What is a sleigh bed?","text":"<p>A sleigh bed is a style of bed that is characterized by its distinctive scrolled or curved headboard and footboard, resembling a traditional sleigh or sled.<\/p>"}},"question_dkRy9b":{"type":"question","settings":{"icon":"none","heading":"What's the recommended care and maintenance for the Sleigh Bed?","text":"<p>To maintain the beauty of your Sleigh Bed, we recommend regular dusting with a soft, dry cloth. Avoid using harsh chemicals, as they may damage the finish. For specific care instructions, refer to the provided care guide or contact our customer support.<\/p>"}},"question_tzW6DE":{"type":"question","settings":{"icon":"none","heading":"Can the Sleigh Bed be ordered in custom sizes or finishes?","text":"<p>We currently offer a range of standard sizes and finishes for the Sleigh Bed. For customizations beyond these options, please contact our customer service team to discuss the feasibility and potential options.<\/p>"}},"question_hjrYjQ":{"type":"question","settings":{"icon":"none","heading":"What is the warranty on the Sleigh Bed?","text":"<p>We stand behind the quality of our products. The Sleigh Bed comes with a 1-year warranty, ensuring your satisfaction and peace of mind.<\/p>"}},"question_BfYm73":{"type":"question","settings":{"icon":"none","heading":"Is assembly required, and how difficult is it?","text":"<p>Yes, assembly is required. However, our Sleigh Bed comes with <a href=\"https:\/\/www.bedroomking.co.uk\/pages\/bed-assembly-instructions\" target=\"_blank\" title=\"https:\/\/www.bedroomking.co.uk\/pages\/bed-assembly-instructions\">easy-to-follow instructions <\/a>and all the necessary hardware. We also offer assembly.<\/p>"}}},"block_order":["question_MUVNpT","question_dkRy9b","question_tzW6DE","question_hjrYjQ","question_BfYm73"],"settings":{"heading":"Frequently Asked Questions","heading_align":"text-center","color_scheme":"1","full_width":true}},"logo_list_QDAJxC":{"type":"logo-list","blocks":{"logo_Lxzy4b":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/dividebuy-logo-full-colour-rgb.png","url":"","logo_width":120,"text":""}},"logo_kGhd8T":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/Klarna_Payment_Badge_svg.webp","url":"","logo_width":120,"text":""}},"logo_ypWmxJ":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/CP_logo_badge_6328x2204_blackmint_png.png","url":"","logo_width":120,"text":""}},"logo_JQVwPL":{"type":"logo","disabled":true,"settings":{"image":"shopify:\/\/shop_images\/Logo_Grape-black.png","url":"","logo_width":120,"text":""}},"logo_3QrNDt":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/shop.png","url":"","logo_width":120,"text":""}},"logo_cFAUrX":{"type":"logo","settings":{"image":"shopify:\/\/shop_