    "faq_wJQq67": {
      "type": "faq",
      "blocks": {
        "question_FYcpiP": {
          "type": "question",
          "settings": {
            "icon": "none",
            "heading": "What are the different types of mattresses available?",
            "text": "<ul><li><strong>Pocket Sprung Mattresses:</strong> A pocket-sprung mattress comprises individual pocket springs, each encased in fabric. These springs operate independently, responding specifically to the pressure they receive.</li><li><strong>Full Memory Mattresses:</strong> Memory foam mattresses are engineered to gently adjust to the body under pressure, promoting even weight distribution.</li><li>Orthopaedic Mattresses: An orthopaedic mattress, is specifically engineered to provide a firm sleep surface that offers precise support for your back and joints.</li><li><strong>Pillow Top Mattresses:</strong> Pillow top mattresses, provide a perfect blend of softness for the body contouring and firmness for necessary support. These mattresses effectively relieve pressure points like shoulders and hips, providing pain relief for various sleeping positions.</li><li><strong>Memory Spring Mattresses:</strong> Spring mattresses, are sleeping surfaces designed with numerous metal springs to serve as an essential support system. In addition, these mattresses consist of softer cushioning layers intended to enhance overall comfort.</li><li><strong>Cool Gel Memory Mattresses:</strong> The cool Gel Memory Foam is crafted to distribute body heat for a comfortable sleeping temperature. These mattress covers are constructed with breathable fabrics to promote airflow, ensuring a cool and comfortable sleeping experience.</li></ul>"
          }
        },
        "question_Wb6qpX": {
          "type": "question",
          "settings": {
            "icon": "none",
            "heading": "What are the differences between memory foam, pocket spring, and orthopedic mattresses?    ",
            "text": "<p>Memory foam mattresses adjust to the shape of your body, providing personalized support and pressure relief. Pocket spring mattresses feature individually wrapped coils that offer targeted support. Orthopedic mattresses are designed to promote spinal alignment and relieve pressure points.</p>"
          }
        },
        "question_WkPn6z": {
          "type": "question",
          "settings": {
            "icon": "none",
            "heading": "How should I care for my new mattress?",
            "text": "<p>To prolong the lifespan of your mattress, we recommend rotating it regularly and using a mattress protector to guard against spills and stains. Additionally, ensure proper ventilation and avoid placing heavy objects on the mattress to prevent damage.</p>"
          }
        },
        "question_imYPVA": {
          "type": "question",
          "settings": {
            "icon": "none",
            "heading": "Do your mattresses require a specific type of bed frame or foundation?",
            "text": "<p>Our mattresses are compatible with most bed frames and foundations, including platform beds, slatted frames, and adjustable bases. However, it's important to ensure that your bed frame provides adequate support to prevent sagging and maintain the integrity of the mattress</p>"
          }
        },
        "question_QRkbaQ": {
          "type": "question",
          "settings": {
            "icon": "none",
            "heading": "Do your mattresses come with a warranty?",
            "text": "<p>Yes, all our mattresses come with a warranty to ensure your peace of mind. Please refer to the product specifications for warranty details.</p>"
          }
        },
        "question_UjgVQY": {
          "type": "question",
          "settings": {
            "icon": "none",
            "heading": "What is the lifespan of your mattresses?",
            "text": "<p>The lifespan of our mattresses varies depending on factors such as usage, care, and mattress type. On average, our mattresses are designed to last between 7 to 10 years with proper maintenance and care.</p>"
          }
        }
      },
      "block_order": [
