    "media_with_text_Fafpmp": {
      "type": "media-with-text",
      "blocks": {
        "heading_7iJkdY": {
          "type": "heading",
          "settings": {
            "heading": "Breathable and Cooling Materials",
            "heading_size": "h2",
            "heading_h1": false
          }
        },
        "text_7fxrgK": {
          "type": "text",
          "settings": {
            "text": "<p>Our <a href=\"https://www.bedroomking.co.uk/collections/mattresses\" target=\"_blank\" title=\"https://www.bedroomking.co.uk/collections/mattresses\"><strong>mattresses</strong></a> are designed with <strong>breathable and cooling materials</strong> to ensure a comfortable and temperature-regulated sleep experience. Featuring advanced airflow technology and moisture-wicking fabrics, these <strong>mattresses</strong> help dissipate heat and prevent overheating throughout the night. Whether you prefer memory foam, orthopaedic or pillow top, our cooling designs promote better air circulation, keeping you fresh and well-rested. Enjoy a cooler, more comfortable night's sleep with our expertly crafted <strong>mattresses</strong>.</p>",
            "enlarge_text": false
          }
        }
      },
      "block_order": [
        "heading_7iJkdY",
        "text_7fxrgK"
      ],
