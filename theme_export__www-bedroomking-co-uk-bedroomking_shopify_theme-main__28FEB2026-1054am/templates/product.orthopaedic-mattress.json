        "heading_7fE3V9": {
          "type": "heading",
          "settings": {
            "heading": "Hypoallergenic Fabric",
            "heading_size": "h2",
            "heading_h1": false
          }
        },
        "text_9x9xGQ": {
          "type": "text",
          "settings": {
            "text": "<p>Our <a href=\"https://www.bedroomking.co.uk/collections/mattresses\" target=\"_blank\" title=\"https://www.bedroomking.co.uk/collections/mattresses\"><strong>mattresses</strong></a> are crafted with <strong>hypoallergenic fabric</strong> to create a cleaner, healthier sleep environment. Designed to resist <strong>dust mites, allergens, and bacteria</strong>, this fabric helps prevent irritation, making it ideal for allergy sufferers and those with sensitive skin. Whether you choose Orthopaedic, memory foam, hybrid, or pocket spring, our king size <strong>mattresses</strong> ensure a fresh, hygienic, and comfortable night’s sleep. Sleep peacefully with a double <strong>mattress</strong> that cares for your well-being.</p>",
