rames ensure hassle-free maintenance, allowing you to focus on enjoying your comfortable and stylish King size storage bed.<\/p>","enlarge_text":false}}},"block_order":["heading_ryz3zp","text_UH9aRP"],"settings":{"image":"shopify:\/\/shop_images\/2_4807cd06-a339-4f92-b8fc-75f63f8b6c41.jpg","video_external":"","video_description":"","video_autoplay":false,"layout":"right","image_fit":"contain","media_width":50,"media_scale":100,"text_align":"text-start","color_scheme":"none"}},"media_with_text_RMtjiR":{"type":"media-with-text","blocks":{"heading_XdrNzz":{"type":"heading","settings":{"heading":"Tufted Headboard Design","heading_size":"h2","heading_h1":false}},"text_D4j7Rz":{"type":"text","settings":{"text":"<p>Infuse a touch of classic charm into your bedroom with bed<br\/>frames boasting a Tufted Headboard Design. Opt for the luxurious King Size Bed with 4 Drawers and enjoy the timeless elegance of button tufting for a visually appealing pattern.<\/p>","enlarge_text":false}}},"block_order":["heading_XdrNzz","text_D4j7Rz"],"settings":{"image":"shopify:\/\/shop_images\/head.webp","video_external":"","video_description":"","video_autoplay":false,"layout":"left","image_fit":"contain","media_width":50,"media_scale":100,"text_align":"text-start","color_scheme":"none"}},"media_with_text_cBUcgr":{"type":"media-with-text","blocks":{"heading_kttBV3":{"type":"heading","settings":{"heading":"Storage Options","heading_size":"h2","heading_h1":false}},"text_krxTXP":{"type":"text","settings":{"text":"<p>Maximize your bedroom space with our King size bed frame<br\/>with storage options. Our King Size Ottoman Bed combines style with functionality, offering discreet storage solutions to keep your space organized and clutter-free.<\/p>","enlarge_text":false}}},"block_order":["heading_kttBV3","text_krxTXP"],"settings":{"image":"shopify:\/\/shop_images\/1_ae9de92c-52f1-4acc-b970-2b0cc1088d43.jpg","video_external":"","video_description":"","video_autoplay":false,"layout":"right","image_fit":"contain","media_width":50,"media_scale":100,"text_align":"text-start","color_scheme":"none"}},"slideshow_3e3jXr":{"type":"slideshow","blocks":{"slide_Fxpe39":{"type":"slide","settings":{"image_desktop":"shopify:\/\/shop_images\/1800_X_900_8_25.png","image_mobile":"shopify:\/\/shop_images\/Shopify_Mobile_portrait_17.png","url":"","overlay_position":"justify-center items-center","overlay_text_align":"text-center","mob_center_text":false,"subheading":"","heading":"","heading_color":"#ffffff","heading_size":"h0","heading_h1":false,"text":"","enlarge_text":true,"button_1_label":"","button_1_link":"","button_1_style":"btn btn--primary","button_2_label":"","button_2_link":"","button_2_style":"btn btn--primary","transparent_content_color":"#ffffff","countdown_show":false,"countdown_end_date":"","countdown_end_time":"","countdown_end_text":"","enlarge_end_text":false,"countdown_hide_on_end":false,"use_custom_colors":false,"count_color":"#ffffff","bg_color":"#070707","bg_grad":""}}},"block_order":["slide_Fxpe39"],"settings":{"height_mode":"auto","fixed_height_desktop":600,"fixed_height_mobile":350,"mobile_stacked":false,"nav_style":"slideshow_nav_lines","pagination_color":"#ffffff","nav_position":"justify-center","transition":"slide-fade","autoplay":true,"slider_pause":false,"autoplay_speed":5,"color_scheme":"white","full_width":true,"tint_color":"#000000","tint_opacity":0,"accessibility_info":"","prevent_animation":true}},"multi_column_kiEndT":{"type":"multi-column","blocks":{"column_Ed3rL4":{"type":"column","settings":{"enable_media":true,"image":"shopify:\/\/shop_images\/harper-non-tufted-upholstered-bed-xl_1.jpg","media_scale":100,"heading":"","text":"<h2>Fast Delivery<\/h2><p>Experience the convenience of fast delivery when you shop with us. Our commitment to exceptional service ensures that your Bed frame with mattress is swiftly processed and delivered to your doorstep. Enjoy the ease and efficiency of our fast delivery service, bringing comfort and style to your home in no time.<\/p>","button_label":"","button_link":""}},"column_nh3dgA":{"type":"column","settings":{"enable_media":true,"image":"shopify:\/\/shop_images\/Cavill_Grey_Bed_D_2000x_9d0599cb-fc00-4ed9-b972-b540e23b1596.webp","media_scale":100,"heading":"","text":"<h2>12 Months Warranty<\/h2><p>Our King size bed  comes with a comprehensive 12-month warranty, offering you peace of mind and assurance in the quality of our products. Experience superior craftsmanship with the added security of our warranty, ensuring your satisfaction with our king size ottoman bed<\/p>","button_label":"","button_link":""}}},"block_order":["column_Ed3rL4","column_nh3dgA"],"settings":{"title":"","heading_align":"text-start","button_label":"","button_link":"","layout":"grid","column_size":"large","column_align":"center","image_ratio":"1","color_scheme":"1","button_style":"btn btn--secondary"}},"testimonials_k78Di3":{"type":"testimonials","blocks":{"testimonial_twi4ep":{"type":"testimonial","settings":{"testimonial":"<p>Purchased the upholstered bed recently and it has exceeded my expectations! The sleek design, premium materials, and attention to detail make it a true statement piece in my bedroom. The plush upholstery not only adds a touch of sophistication but also ensures a comfortable and restful night's sleep. Couldn't be happier with my purchase!<\/p>","author":"Ethan Pane","author_info":"","show_star_rating":true,"star_rating":5}},"testimonial_Pmtnra":{"type":"testimonial","settings":{"testimonial":"<p>Absolutely in love with my new upholstered bed! The storage compartments are a game-changer, providing a practical solution for keeping my bedroom organized. The tufted headboard adds a touch of elegance and complements the overall stylish design. Highly recommend for anyone looking for a perfect blend of style and<br\/>functionality!<\/p>","author":"Lily Alison","author_info":"","show_star_rating":true,"star_rating":5}},"testimonial_DkmHBc":{"type":"testimonial","settings":{"testimonial":"<p>My upholstered bed is a dream come true! The plush fabric, sturdy frame, and meticulous craftsmanship make for an absolute comfort haven in my bedroom. The blend of luxury and comfort is unparalleled, and I find myself looking forward to bedtime every night. A perfect addition to my sanctuary!<\/p>","author":"Kelly Afong","author_info":"","show_star_rating":true,"star_rating":5}}},"block_order":["testimonial_twi4ep","testimonial_Pmtnra","testimonial_DkmHBc"],"settings":{"heading":"CUSTOMER RAVES","show_quotes":true,"testimonial_size":"h4","text_position":"justify-center","text_align":"text-center justify-center","nav_style":"slideshow_nav_lines","transition":"slide-fade","autoplay":false,"slider_pause":false,"autoplay_speed":5,"color_scheme":"1","full_width":true}},"recommendations":{"type":"product-recommendations","settings":{"heading":"YOU MAY ALSO LIKE","heading_align":"text-center","layout":"carousel","card_size_mobile":"large","card_size":"medium","products_to_show":8}},"faq_K9VnUr":{"type":"faq","blocks":{"question_kQgbqx":{"type":"question","settings":{"icon":"none","heading":"What is an upholstered bed?","text":"<p>An upholstered bed is a type of bed frame that features a padded and fabric-covered headboard, footboard, and often side panels.<\/p>"}},"question_3Pe7hU":{"type":"question","settings":{"icon":"none","heading":"What materials are used in your upholstered beds?","text":"<p>Our upholstered beds are crafted using high-quality materials, including durable hardwood for the frame and premium fabrics for the upholstery. We ensure that all materials used are ethically sourced and built to last.<\/p>"}},"question_CDYKzb":{"type":"question","settings":{"icon":"none","heading":"How do I care for my upholstered bed","text":"<p>To maintain the pristine condition of your bed, we recommend regular vacuuming to remove dust and occasional spot cleaning for any spills. Always use a mild fabric cleaner and test on an inconspicuous area first. Avoid exposing the bed to direct sunlight for prolonged periods.<\/p>"}},"question_UQXUea":{"type":"question","settings":{"icon":"none","heading":"Is assembly difficult for upholstered beds?","text":"<p>No, upholstered beds typically come with clear assembly instructions, and assembly is manageable with basic tools. Some models may also feature easy-to-assemble designs. We also provide assembly option for some little added charges.<\/p>"}},"question_ARyiFj":{"type":"question","settings":{"icon":"none","heading":"Can I purchase an upholstered bed with a mattress included?","text":"<p>Yes, you can select the size and type of mattress from our store. This option provides a hassle-free solution for those looking to upgrade their entire sleep setup.<\/p>"}}},"block_order":["question_kQgbqx","question_3Pe7hU","question_CDYKzb","question_UQXUea","question_ARyiFj"],"settings":{"heading":"Frequently Asked Questions","heading_align":"text-center","color_scheme":"1","full_width":true}},"slideshow_Dte3JH":{"type":"slideshow","blocks":{"slide_dMcLcH":{"type":"slide","settings":{"image_desktop":"shopify:\/\/shop_images\/17.png","image_mobile":"shopify:\/\/shop_images\/17.png","url":"","overlay_position":"justify-center items-center","overlay_text_align":"text-center","mob_center_text":false,"subheading":"","heading":"","heading_color":"#ffffff","heading_size":"h0","heading_h1":false,"text":"","enlarge_text":true,"button_1_label":"","button_1_link":"","button_1_style":"btn btn--primary","button_2_label":"","button_2_link":"","button_2_style":"btn btn--primary","transparent_content_color":"#ffffff","countdown_show":false,"countdown_end_date":"","countdown_end_time":"","countdown_end_text":"","enlarge_end_text":false,"countdown_hide_on_end":false,"use_custom_colors":false,"count_color":"#ffffff","bg_color":"#ffffff","bg_grad":""}}},"block_order":["slide_dMcLcH"],"settings":{"height_mode":"auto","fixed_height_desktop":600,"fixed_height_mobile":350,"mobile_stacked":false,"nav_style":"slideshow_nav_l