    "media_with_text_rthHci": {
      "type": "media-with-text",
      "blocks": {
        "heading_3VWUdX": {
          "type": "heading",
          "settings": {
            "heading": "Kid's Bed with Drawers",
            "heading_size": "h3",
            "heading_h1": false
          }
        },
        "text_wzrdhN": {
          "type": "text",
          "settings": {
            "text": "<p>Experience clutter-free living with <a href=\"https://www.bedroomking.co.uk/collections/childrens-beds\" target=\"_blank\" title=\"https://www.bedroomking.co.uk/collections/childrens-beds\">kid's beds</a> that offer great storage. Featuring a bed with drawers, these beds provide a convenient storage solution. Featuring built-in storage drawers underneath, it offers the ideal spot to tuck away toys, clothes, books, or extra bedding.<br/><br/></p>",
            "enlarge_text": false
          }
        }
      },
      "block_order": [
        "heading_3VWUdX",
        "text_wzrdhN"
      ],
      "custom_css": [
        ".section__block.section__block--heading {font-size: 30px; color: #806642;}",
        ".section__block.reading-width p {line-height: 1.8; font-size: 16px; color: #555;}"
      ],
      "settings": {
