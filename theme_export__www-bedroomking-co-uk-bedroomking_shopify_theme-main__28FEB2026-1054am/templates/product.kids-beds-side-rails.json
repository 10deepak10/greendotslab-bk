       {{ length_in | round: 2 }} inch\n                        {% else %}\n                        NA\n                        {% endif %}\n                    </td>\n                    <td>\n                        {% if hb and hb != blank %}\n                        {{ hb }}\n                        {% else %}\n                        NA\n                        {% endif %}\n                    </td>\n                </tr>\n                <tr>\n                    <td>C - Footboard Height</td>\n                    {% assign fb = product.metafields.custom.footboard_height %}\n                    <td>\n                        {% if fb and fb != blank %}\n                        {% assign length_cm = fb | plus: 0 %}\n                        {% assign length_in = length_cm | times: 0.393701 %}\n                        {{ length_in | round: 2 }} inch\n                        {% else %}\n                        NA\n                        {% endif %}\n                    </td>\n                    <td>\n                        {% if fb and fb != blank %}\n                        {{ fb }}\n                        {% else %}\n                        NA\n                        {% endif %}\n                    </td>\n                </tr>\n\n            </table>\n        </div>\n        <div id=\"if-size-6ft\" class=\"specs\" style=\"display: none;\">\n            \n            <p><span id=\"prod-size-selected\">6FT Super King Size</span> with FREE Headboard</p>\n            \n            <table>\n                <tr>\n                    <td>A - Frame Length</td>\n                    {% assign len = product.metafields.custom.super_frame_length %}\n                    <td>\n                        {% if len and len != blank %}\n                        {% assign length_cm = len | plus: 0 %}\n                        {% assign length_in = length_cm | times: 0.393701 %}\n                        {{ length_in | round: 2 }} inch\n                        {% else %}\n                        NA\n                        {% endif %}\n                    </td>\n                    <td>\n                        {% if len and len != blank %}\n                        {{ len }}\n                        {% else %}\n                        NA\n                        {% endif %}\n                    </td>\n                </tr>\n                <tr>\n                    <td>B - Headboard Width</td>\n                    {% assign hb = product.metafields.custom.super_headboard_width %}\n                    <td>\n                        {% if hb and hb != blank %}\n                        {% assign length_cm = hb | plus: 0 %}\n                        {% assign length_in = length_cm | times: 0.393701 %}\n                        {{ length_in | round: 2 }} inch\n                        {% else %}\n                        NA\n                        {% endif %}\n                    </td>\n                    <td>\n                        {% if hb and hb != blank %}\n                        {{ hb }}\n                        {% else %}\n                        NA\n                        {% endif %}\n                    </td>\n                </tr>\n                <tr>\n                    <td>C - Footboard Height</td>\n                    {% assign fb = product.metafields.custom.footboard_height %}\n                    <td>\n                        {% if fb and fb != blank %}\n                        {% assign length_cm = fb | plus: 0 %}\n                        {% assign length_in = length_cm | times: 0.393701 %}\n                        {{ length_in | round: 2 }} inch\n                        {% else %}\n                        NA\n                        {% endif %}\n                    </td>\n                    <td>\n                        {% if fb and fb != blank %}\n                        {{ fb }}\n                        {% else %}\n                        NA\n                        {% endif %}\n                    </td>\n                </tr>\n\n            </table>\n\n        </div>\n        </div>\n    </div>\n\n    <p class=\"note\">\n        <span> <strong>Note:</strong> Headboard and Footboard width is included in the frame length</span>\n        Please allow for a tolerance of +/- 2cm (1 in)\n    </p>\n</div>",
