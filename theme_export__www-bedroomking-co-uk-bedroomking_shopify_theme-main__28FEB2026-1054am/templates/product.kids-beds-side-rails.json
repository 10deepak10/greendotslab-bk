        "column_A67d9P": {
          "type": "column",
          "settings": {
            "enable_media": true,
            "image": "shopify://shop_images/Fast_Delivery_8.png",
            "media_scale": 100,
            "heading": "",
            "text": "<h3>2 Years Warranty</h3><p>At Bedroomking, we stand behind the quality and craftsmanship of our beds, <a href=\"https://www.bedroomking.co.uk/collections/all-bed-frames\" target=\"_blank\" title=\"https://www.bedroomking.co.uk/collections/all-bed-frames\">bedframes</a> and <a href=\"https://www.bedroomking.co.uk/collections/mattresses\" target=\"_blank\" title=\"https://www.bedroomking.co.uk/collections/mattresses\">mattresses</a>. We provide you with a 2-years warranty when you purchase a new product from our range of divans, bed frames, mattresses, TV beds, bedroom furniture and kid’s beds to<br/>ensure your satisfaction and peace of mind. </p>",
            "button_label": "",
            "button_link": ""
          }
        }
      },
