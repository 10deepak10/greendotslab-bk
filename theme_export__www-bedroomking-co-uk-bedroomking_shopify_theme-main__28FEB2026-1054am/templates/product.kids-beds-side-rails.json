      "type": "multi-column",
      "blocks": {
        "column_imkqdW": {
          "type": "column",
          "settings": {
            "enable_media": true,
            "image": "shopify://shop_images/Fast_Delivery_6_1.png",
            "media_scale": 100,
            "heading": "",
            "text": "<h3>Express Delivery</h3><p>Need your new bed in a hurry? Choose our <em>Express Delivery</em> option at checkout and enjoy faster delivery within just <strong>3 to 5 working days</strong>. Fast, reliable, and stress-free so you can enjoy your new bed sooner than you think.<br/><br/></p>",
