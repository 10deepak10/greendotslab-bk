        "text_VDa3ME": {
          "type": "text",
          "settings": {
            "text": "<p>From a Spare Room in Yorkshire to Thousands of Bedrooms Across the UK. Some businesses are born from spreadsheets. Ours started in a small bedroom — quite literally.</p>",
            "enlarge_text": true
          }
        },
        "button_9CaK6P": {
          "type": "button",
          "settings": {
            "button_label": "",
            "button_link": "",
            "button_style": "btn btn--secondary"
