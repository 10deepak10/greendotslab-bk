    "rich_text_zj6bPC": {
      "type": "rich-text",
      "blocks": {
        "text_BHeFhE": {
          "type": "text",
          "settings": {
            "text": "<p>This shaped how we designed our beds. Every headboard was tweaked. Every drawer runner was tested. We even adjusted fabric shades after one customer told us her grey bed looked “a little too blue in sunlight.” These weren’t complaints — they were insights. We listened, and we improved.</p><p> </p>",
            "enlarge_text": false
          }
        }
      },
      "block_order": [
        "text_BHeFhE"
      ],
      "name": "Rich text",
      "settings": {
