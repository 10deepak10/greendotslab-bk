        "heading_F9CtCF": {
          "type": "heading",
          "settings": {
            "heading": "Upholstery & Materials",
            "heading_size": "h3",
            "heading_h1": false
          }
        },
        "text_yJ8t6K": {
          "type": "text",
          "settings": {
            "text": "<p>We handpick every material for comfort, longevity, and style. Our current fabric lineup includes:</p><ul><li>Plush Velvet</li><li>Naples</li><li>Crushed Velvet</li><li>Linen</li><li>Chenille</li></ul><p>Each one is available in a curated palette of 5-10 shades. We rotate options seasonally, based on customer feedback, design trends, and supplier innovations.</p><p>Want to feel the difference? We offer free swatch samples shipped to your door.</p>",
            "enlarge_text": false
          }
        }
      },
