    "media_with_text_KbrXfT": {
      "type": "media-with-text",
      "blocks": {
        "heading_QYfj6W": {
          "type": "heading",
          "settings": {
            "heading": "Sizes & Fit – British Beds, Perfectly Sized",
            "heading_size": "h3",
            "heading_h1": false
          }
        },
        "text_LCgFMW": {
          "type": "text",
          "settings": {
            "text": "<p>We offer all standard UK sizes:</p><ul><li>Single (3ft)</li><li>Small Double (4ft)</li><li>Double (4ft 6in)</li><li>King (5ft)</li><li>Super King (6ft)</li></ul><p>Because every bed is made to order, we can also accommodate bespoke sizes. Need an extra-short bed for a loft conversion? Or a low-profile frame for older relatives? No problem.</p><p>Our customers regularly tell us this flexibility is what sets us apart.</p>",
            "enlarge_text": false
          }
        }
      },
      "block_order": [
